* text=auto

# Force Linux line endings for scripts
*.sh text eol=lf

# Force Windows line endings for Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf

# .NET files
*.cs text
*.csproj text
*.sln text

# Move / blockchain files
*.move text
*.toml text

# JSON / configs
*.json text
*.yml text
*.yaml text