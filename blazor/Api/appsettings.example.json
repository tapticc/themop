{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Sui": {
        "DefaultNetwork": "testnet", //testnet, devnet, localnet, mainnet

        "RpcUrls": {
            "localnet": "http://127.0.0.1:9000",
            "devnet": "https://fullnode.devnet.sui.io:443",
            "testnet": "https://fullnode.testnet.sui.io:443",
            "mainnet": "https://fullnode.mainnet.sui.io:443"
        },

        "GraphQLEndpoints": {
            "localnet": "http://127.0.0.1:9125/graphql",
            "devnet": "https://graphql.devnet.sui.io/graphql",
            "testnet": "https://graphql.testnet.sui.io/graphql",
            "mainnet": "https://graphql.mainnet.sui.io/graphql"
        },

        "Packages": {
            "World": "0xWORLD_PACKAGE",
            "TheMopPackageId": "0xMOP_PACKAGE",
            "ItemConfigRegistryId": "0xITEMCONFIGREGISTRYID"
        },

        "Objects": {
            "RoleRegistry": "0xROLE_REGISTRY",
            "ComplianceConfig": "0xCONFIG"
        }
    }
}
