@page "/gatehome"
@using Client.Models
@inject NavigationManager Nav
@inject AppState AppState

<PageTitle>Gate Home</PageTitle>

<div class="mop-config-shell">
    <div class="mop-config-card">
        <div class="mop-config-title">Ministry Gate Interface</div>

        <div class="mop-config-text">
            This gate has not yet been assigned its Ministry routing approval.
        </div>

        <div class="mop-config-text-small">
            Retrieve the Assembly ID from the gate management interface and continue to configuration.
        </div>

        <input class="mop-input"
               placeholder="Enter Gate Assembly ID"
               @bind="AssemblyId" />

        <button class="mop-btn" @onclick="ContinueToConfigure">
            Continue
        </button>
    </div>
</div>

@code {
    private string AssemblyId = "";

    private void ContinueToConfigure()
    {
        if (string.IsNullOrWhiteSpace(AssemblyId))
            return;

        Nav.NavigateTo($"/gate/{AssemblyId}", false);
    }
}
