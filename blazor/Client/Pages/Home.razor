@page "/"
@using Client.Models
@using Common.Events
@inject AppState AppState
@inject Client.Services.SuiApiClient Api
@inject NavigationManager Nav

<PageTitle>Ministry Profile</PageTitle>

<div class="mop-profile-shell">
	@if (!string.IsNullOrWhiteSpace(Error))
	{
		<div class="alert alert-danger">@Error</div>
	}
	else if (IsLoading)
	{
		<div class="mop-profile-card">
			<div class="mop-profile-muted">Loading ministry profile...</div>
		</div>
	}
	else if (Profile is not null)
	{
		<div class="mop-profile-card mop-profile-header">
			<div class="mop-profile-title">Ministry Profile</div>
			<div class="mop-profile-name">@Profile.CharacterName</div>
			<div class="mop-profile-sub">@ShortId(Profile.CharacterId)</div>
		</div>

		<div class="mop-profile-card">
			<div class="mop-profile-section-title">Standing</div>

			<div class="mop-profile-stat-grid">
				<div class="mop-profile-stat">
					<div class="mop-profile-stat-label">Compliance Points</div>
					<div class="mop-profile-stat-value">@AppState.CharacterSummary?.CompliancePoints</div>
				</div>

				<div class="mop-profile-stat">
					<div class="mop-profile-stat-label">Ministry Points</div>
					<div class="mop-profile-stat-value">@AppState.CharacterSummary?.MinistryPoints</div>
				</div>
			</div>
		</div>

		<div class="mop-profile-card">
			<button class="mop-btn" @onclick="NavToSetupSSU">
				Setup SSU
			</button>
		</div>

		<div class="mop-profile-card">
			<button class="mop-btn" @onclick="NavToSetupGate">
				Setup Gate
			</button>
		</div>
	}
</div>

@code {
	private PlayerProfilePointsDto? Profile;
	private string? Error;
	private bool IsLoading;


	protected override async Task OnInitializedAsync()
	{
		await LoadProfile();
	}

	private bool IsCurrentPlayer(string? address) =>
		!string.IsNullOrWhiteSpace(address) &&
		string.Equals(address, AppState.WalletAddress, StringComparison.OrdinalIgnoreCase);

	private string DisplayPlayerName(PlayerDepositEventRow row)
	{
		if (!string.IsNullOrWhiteSpace(row.CharacterName))
			return row.CharacterName;

		return ShortId(row.CharacterAddress);
	}

	private async Task LoadProfile(bool forceRefresh = false)
	{
		Error = null;
		IsLoading = Profile is null;

		try
		{
			if (AppState.CharacterSummary is null || string.IsNullOrWhiteSpace(AppState.WalletAddress)
				|| AppState.CharacterSummary.CharacterId == null)
			{
				Error = "Character session is missing.";
				return;
			}

			var points = await Api.GetPlayerPointsAsync(
				AppState.WalletAddress,
				forceRefresh);

			AppState.CharacterSummary.CompliancePoints = points.CompliancePoints;
			AppState.CharacterSummary.MinistryPoints = points.MinistryPoints;

			Profile = await Api.GetPlayerProfilePointsAsync(
				AppState.WalletAddress,
				AppState.CharacterSummary.CharacterId,
				AppState.CharacterSummary.CharacterName ?? "Unknown",
				points.MinistryPoints,
				forceRefresh);
		}
		catch (Exception ex)
		{
			Error = ex.Message;
		}
		finally
		{
			IsLoading = false;
		}
	}

	private static string ShortId(string? value)
	{
		if (string.IsNullOrWhiteSpace(value) || value.Length < 14)
			return value ?? "";

		return $"{value[..8]}...{value[^6..]}";
	}

	private string GetPlayerName(string address)
	{
		if (string.Equals(
			address,
			AppState.WalletAddress,
			StringComparison.OrdinalIgnoreCase))
			return AppState.CharacterSummary?.CharacterName ?? "You";

		return ShortId(address);
	}

	private void NavToSetupSSU()
	{
		Nav.NavigateTo($"/setupssu", false);
	}

	private void NavToSetupGate()
	{
		Nav.NavigateTo($"/setupgate", false);
	}
}