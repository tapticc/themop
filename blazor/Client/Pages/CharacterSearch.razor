@page "/character-search"
@using Common.Sui
@inject Client.Services.SuiApiClient Api
@inject NavigationManager Nav

<PageTitle>Character Search</PageTitle>

<div class="mop-section">
    <h1 class="mop-directive-title">Known Characters</h1>
    <div class="mop-section-rule"></div>

    <p class="eve-text-muted">
        Browse known PlayerProfile records and select a wallet for role administration.
    </p>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3">
        @_error
    </div>
}

@if (_page is not null)
{
    <div class="row g-2 align-items-end mt-3">
        <div class="col-12 col-md-5">
            <label class="form-label">Known Character</label>
            <select class="form-select" @bind="_selectedCachedWalletAddress">
                <option value="">-- Select cached character --</option>
                @foreach (var item in _cachedCharacters)
                {
                    <option value="@item.WalletAddress">
                        @item.CharacterName (@item.WalletAddress)
                    </option>
                }
            </select>
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label">Wallet Address</label>
            <input class="form-control"
                   placeholder="Optional wallet address"
                   @bind="_walletFilter" />
        </div>

        <div class="col-auto">
            <RadzenButton Text="Search"
                          Click="@Search"
                          Disabled="@_loading"
                          class="mop-button-authority" />
        </div>

        <div class="col-auto">
            <RadzenButton Text="Clear"
                          Click="@ClearSearch"
                          Disabled="@_loading"
                          class="mop-button-authority"
                          Visible="@(!string.IsNullOrWhiteSpace(_walletFilter) || !string.IsNullOrWhiteSpace(_characterNameFilter))" />
        </div>
    </div>

    <table class="mop-table">
        <thead>
            <tr>
                <th>Character</th>
                <th>Wallet</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _page.Items)
            {
                <tr>
                    <td>@item.CharacterName</td>
                    <td class="mop-dossier-value">@item.CharacterAddress</td>
                    <td>
                        <RadzenButton Text="View Roles"
                                      Click="@(() => ViewRoles(item.CharacterAddress))"
                                      class="mop-button-authority" />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3 d-flex gap-2">
        <RadzenButton Text="Refresh"
                      Click="@LoadPage"
                      class="mop-button" />

        <RadzenButton Text="Previous Page"
                      Disabled="@(_previousCursors.Count == 0 || _loading)"
                      Click="@LoadPreviousPage"
                      class="mop-button" />

        <RadzenButton Text="Next Page"
                      Disabled="@(_page?.HasNextPage != true || _loading)"
                      Click="@LoadNextPage"
                      class="mop-button-authority" />
    </div>
}

@code {
    private PagedKnownCharactersResponse? _page;
    private string? _error;
    private bool _loading;
    private readonly Stack<string?> _previousCursors = new();
    private string? _currentCursor;
    private int pageSize = 20;

    private string? _walletFilter;
    private string? _characterNameFilter;
    private List<CachedCharacterLookup> _cachedCharacters = new();

    private string? _selectedCachedWalletAddress
    {
        get => _walletFilter;
        set
        {
            _walletFilter = value;

            if (string.IsNullOrWhiteSpace(value))
                return;

            var selected = _cachedCharacters
                .FirstOrDefault(x => string.Equals(
                    x.WalletAddress,
                    value,
                    StringComparison.OrdinalIgnoreCase));

            if (selected is not null)
            {
                _walletFilter = selected.WalletAddress;
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        RefreshCachedCharacters();
        await LoadPage();
    }

    private void RefreshCachedCharacters()
    {
        _cachedCharacters = Api.GetCachedCharacters();
    }

    private async Task Search()
    {
        _currentCursor = null;
        _previousCursors.Clear();
        await LoadPage();
    }

    private async Task ClearSearch()
    {
        _walletFilter = null;
        _characterNameFilter = null;
        _currentCursor = null;
        _previousCursors.Clear();
        await LoadPage();
    }

    private async Task LoadPage()
    {
        try
        {
            _loading = true;
            _error = null;

            _currentCursor = null;
            _previousCursors.Clear();

            _page = await Api.GetKnownCharactersPageAsync(
                pageSize,
                null,
                _walletFilter,
                _characterNameFilter);

            CachePage(_page);
            RefreshCachedCharacters();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadNextPage()
    {
        if (_page?.HasNextPage != true || string.IsNullOrWhiteSpace(_page.EndCursor))
            return;

        try
        {
            _loading = true;
            _error = null;

            _previousCursors.Push(_currentCursor);
            _currentCursor = _page.EndCursor;

            _page = await Api.GetKnownCharactersPageAsync(
                pageSize,
                _currentCursor,
                _walletFilter,
                _characterNameFilter);

            CachePage(_page);
            RefreshCachedCharacters();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadPreviousPage()
    {
        if (_previousCursors.Count == 0)
            return;

        try
        {
            _loading = true;
            _error = null;

            _currentCursor = _previousCursors.Pop();

            _page = await Api.GetKnownCharactersPageAsync(
                pageSize,
                _currentCursor,
                _walletFilter,
                _characterNameFilter);

            CachePage(_page);
            RefreshCachedCharacters();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void ViewRoles(string walletAddress)
    {
        Nav.NavigateTo($"/admin-roles?walletAddress={Uri.EscapeDataString(walletAddress)}");
    }

    private void CachePage(PagedKnownCharactersResponse? page)
    {
        if (page?.Items is null || page.Items.Count == 0)
            return;

        foreach (var item in page.Items)
        {
            Api.CacheCharacter(
                item.CharacterAddress,
                item.CharacterName,
                item.CharacterId);
        }
    }
}