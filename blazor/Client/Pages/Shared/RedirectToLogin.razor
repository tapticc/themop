@using Client.Models
@inject NavigationManager Navigation
@inject AppState AppState

@code {

    protected override void OnInitialized()
    {
        var relativeUrl = Navigation.Uri.Replace(Navigation.BaseUri, "/");

        if (!relativeUrl.StartsWith("/login"))
        {
            AppState.ReturnUrl = relativeUrl;
        }

        Navigation.NavigateTo("/login", false);
    }
}