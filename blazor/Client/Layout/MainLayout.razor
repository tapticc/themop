@using Client.Models
@using Client.Services
@inherits LayoutComponentBase
@inject AppState AppState
@inject NavigationManager Nav
@inject SuiInterop SuiInterop
@inject SuiNetworkService Network
@inject SuiWalletService WalletService
@inject IConfiguration Config
@implements IDisposable

<RadzenLayout class="eve-layout">
	<RadzenHeader class="mop-header">
		<div class="mop-header-inner">
			<div class="mop-header-logo">
				<img src="images/TheMOPLogo.png" class="mop-header-logo-img" />
			</div>

			<RadzenMenu class="mop-menu">
				@* <RadzenMenuItem Text="Dashboard" Path="/" Match="NavLinkMatch.All" /> *@
				<RadzenMenuItem Text="Points" Path="/points" />
				<RadzenMenuItem Text="SSU View" Path="/storage/0x46dc4510debbfee4e3e02c998747f4c33043ce0097c10bb5f25b86251c800cde" />
				<RadzenMenuItem Text="SSU Demo" Path="/storage-demo/0x46dc4510debbfee4e3e02c998747f4c33043ce0097c10bb5f25b86251c800cde" />
				<RadzenMenuItem Text="Inventory Demo" Path="/storage-inventory-demo/0x46dc4510debbfee4e3e02c998747f4c33043ce0097c10bb5f25b86251c800cde" />
				
				@if (AppState.RoleContext?.Permissions?.CanAssignRoles == true)
				{
					<RadzenMenuItem Text="Inventory Admin" Path="/admin-inventory" />
					<RadzenMenuItem Text="Role Admin" Path="/admin-roles" />
					<RadzenMenuItem Text="Character Search" Path="/character-search" />
				}
				<RadzenMenuItem Text="Styles Demo" Path="/styles-demo" />
				<RadzenMenuItem Text="Roles" Path="/styles-demo" />
				<RadzenMenuItem Text="Reload" Click="ForceFullReload"/>
			</RadzenMenu>
		</div>
	</RadzenHeader>

	<RadzenBody class="eve-body">
		<div class="eve-content p-3">
			<div class="mop-page">
				@Body
			</div>
		</div>
	</RadzenBody>
</RadzenLayout>

@code {
	private bool _checkingWallet;

	protected override async Task OnInitializedAsync()
	{
		AppState.OnChange += StateHasChanged;

		await SuiInterop.InitAsync(
			Network.Current.Network.ToString().ToLowerInvariant(),
			Network.Current.RpcUrl,
			Network.Current.PreferredWallet
		);

		Network.OnChanged += HandleNetworkChanged;
		Nav.LocationChanged += HandleLocationChanged;
	}

	private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		await CheckWalletStillMatchesAsync();
	}

	private async Task CheckWalletStillMatchesAsync()
	{
		if (_checkingWallet)
			return;

		try
		{
			_checkingWallet = true;

			var currentWallet = await WalletService.GetCurrentAddressAsync();

			if (!AppState.AuthResolved)
			{
				AppState.AuthResolved = true;
				await InvokeAsync(StateHasChanged);
			}

			var currentPath = new Uri(Nav.Uri).AbsolutePath.ToLowerInvariant();

			if (currentPath == "/login")
				return;

			if (string.IsNullOrWhiteSpace(AppState.WalletAddress))
				return;

			if (string.IsNullOrWhiteSpace(currentWallet) ||
				!string.Equals(AppState.WalletAddress, currentWallet, StringComparison.OrdinalIgnoreCase))
			{
				AppState.ResetSession();
				AppState.AuthResolved = true;
				
				if (!string.IsNullOrEmpty(AppState.ReturnUrl))
				{
					var returnUrl = AppState.ReturnUrl;

					AppState.ReturnUrl = null;

					Nav.NavigateTo(returnUrl, false);
				}
				else
				{
					Nav.NavigateTo("/", false);
				}
			}
		}
		finally
		{
			_checkingWallet = false;
		}
	}

	public void Dispose()
	{
		AppState.OnChange -= StateHasChanged;
		Network.OnChanged -= HandleNetworkChanged;
		Nav.LocationChanged -= HandleLocationChanged;
	}

	private async void HandleNetworkChanged()
	{
		await SuiInterop.InitAsync(
			Network.Current.Network.ToString().ToLowerInvariant(),
			Network.Current.RpcUrl,
			Network.Current.PreferredWallet
		);

		await InvokeAsync(StateHasChanged);
	}

	private void ForceFullReload(MenuItemEventArgs args)
	{
		Nav.NavigateTo(Nav.Uri, forceLoad: true);
	}
}
