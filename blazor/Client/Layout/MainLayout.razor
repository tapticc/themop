@using Client.Models
@using Client.Services
@inherits LayoutComponentBase
@inject AppState AppState
@inject NavigationManager Nav
@inject SuiInterop SuiInterop
@inject SuiNetworkService Network
@implements IDisposable

<RadzenLayout class="eve-layout">

	<RadzenHeader class="eve-header">
		<div class="d-flex align-items-center p-2">

			<!-- Logo -->
			<div class="eve-logo fw-bold text-uppercase text-orange me-3">
				THE MINISTRY OF PASSAGE
			</div>

			<!-- Combined Menu -->
			<RadzenMenu class="eve-menu flex-grow-1" Style="height: 20px;">
				<RadzenMenuItem Text="Dashboard" Path="/" Match="NavLinkMatch.All" />
			</RadzenMenu>
		</div>
	</RadzenHeader>

	<RadzenBody class="eve-body">
		<div class="eve-content p-3">
			@Body
		</div>
	</RadzenBody>

</RadzenLayout>

@code {
	protected override async Task OnInitializedAsync()
	{
		AppState.OnChange += StateHasChanged;
		await SuiInterop.InitAsync(
			Network.Current.Network.ToString().ToLowerInvariant(),
			Network.Current.RpcUrl,
			Network.Current.PreferredWallet
		);

		Network.OnChanged += HandleNetworkChanged;
	}

	private async void HandleNetworkChanged()
	{
		await SuiInterop.InitAsync(
			Network.Current.Network.ToString().ToLowerInvariant(),
			Network.Current.RpcUrl,
			Network.Current.PreferredWallet
		);

		await InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		AppState.OnChange -= StateHasChanged;
		Network.OnChanged -= HandleNetworkChanged;
	}
}
