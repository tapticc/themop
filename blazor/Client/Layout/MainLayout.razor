@using Client.Models
@using Client.Services
@inherits LayoutComponentBase
@inject AppState AppState
@inject NavigationManager Nav
@inject SuiInterop SuiInterop
@inject SuiNetworkService Network
@inject SuiWalletService WalletService
@inject IConfiguration Config
@implements IDisposable

<RadzenLayout class="eve-layout">
	<RadzenHeader class="mop-header">
		<div class="mop-header-inner">
			<div class="mop-header-logo">
				<img src="images/TheMOPLogo.png" class="mop-header-logo-img" />
			</div>

			<RadzenMenu class="mop-menu">
				<RadzenMenuItem Text="Operations" Path="/operations" />
				<RadzenMenuItem Text="Reload" Click="ForceFullReload" />
			</RadzenMenu>			
		</div>
		
	</RadzenHeader>

	<RadzenBody class="eve-body">
		<div class="eve-content p-3">
			<div class="mop-page">

				<div class="mop-bulletin-bar">
					<div class="mop-bulletin-glow"></div>

					<div class="mop-bulletin-inner">
						<span class="mop-bulletin-label">MINISTRY NOTICE</span>
						<span class="mop-bulletin-separator">|</span>
						<span class="mop-bulletin-text">@CurrentBulletin</span>
					</div>
				</div>

				@Body
			</div>
		</div>
	</RadzenBody>
</RadzenLayout>

@code {
	private bool _checkingWallet;

	private readonly string[] _bulletins = new[]
		{
		"Your compliance is noted.",
		"Passage is a privilege, not a right.",
		"Submit your forms. Receive your destiny.",
		"All movement must be justified.",
		"The Ministry remembers.",
		"Your route has been approved. For now.",
		"You may proceed. Don’t make it weird.",
		"Unauthorized detours will be corrected.",
		"Efficiency is mandatory.",
		"Please remain where you are. Temporarily.",
		"Your contribution has been recorded.",
		"The queue is eternal. Embrace it.",
		"A polite citizen pays the toll.",
		"Report all suspicious shortcuts.",
		"You have been assigned an acceptable path.",
		"The Ministry thanks you for your obedience.",
		"Your travel request is under review. Forever.",
		"The gate opens for the worthy.",
		"The gate closes for the curious.",
		"Civ points spent wisely are civ points spent.",
		"Stop asking. Start contributing.",
		"Be productive. Be permitted.",
		"Your paperwork is in the right hands. Probably.",
		"The Ministry provides. The Ministry withholds.",
		"You are free to comply.",
		"Your hesitation has been documented.",
		"A citizen who wanders is a citizen who pays.",
		"Access granted. Gratitude expected.",
		"Access denied. Reflect accordingly.",
		"The Ministry does not negotiate with entropy.",
		"Please stand by for authorization.",
		"The safest path is the approved path.",
		"Don’t worry. We’re watching.",
		"Contribute first. Questions later.",
		"Your toll has been accepted.",
		"Your toll has been deemed insufficient.",
		"Civilisation advances one checkbox at a time.",
		"Order is faster than freedom.",
		"You have been selected for passage.",
		"You have been selected for waiting.",
		"All gates serve the Ministry.",
		"All roads lead where we say they do.",
		"Your route is suspiciously creative. Stop that.",
		"Joy is permitted during authorized travel only.",
		"The Ministry appreciates your timely conformity.",
		"Proceed with sanctioned enthusiasm.",
		"Unauthorized heroics are discouraged.",
		"You will be redirected for your convenience.",
		"Your request has been escalated to silence.",
		"Thank you for building civilisation correctly."
	};

	private int _bulletinIndex;
	private string CurrentBulletin => _bulletins[_bulletinIndex];

	private PeriodicTimer? _bulletinTimer;
	private CancellationTokenSource? _bulletinCts;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender) {
			return;
		}

		StateHasChanged();
	}

	protected override async Task OnInitializedAsync()
	{
		AppState.OnChange += StateHasChanged;

		await SuiInterop.InitAsync(
			Network.Current.Network.ToString().ToLowerInvariant(),
			Network.Current.RpcUrl,
			Network.Current.PreferredWallet
		);

		Network.OnChanged += HandleNetworkChanged;
		Nav.LocationChanged += HandleLocationChanged;

		StartBulletinRotation();
	}

	private void StartBulletinRotation()
	{
		_bulletinCts = new CancellationTokenSource();
		_bulletinTimer = new PeriodicTimer(TimeSpan.FromSeconds(8));

		_ = Task.Run(async () =>
		{
			try
			{
				while (await _bulletinTimer.WaitForNextTickAsync(_bulletinCts.Token))
				{
					_bulletinIndex++;
					if (_bulletinIndex >= _bulletins.Length)
						_bulletinIndex = 0;

					await InvokeAsync(StateHasChanged);
				}
			}
			catch (OperationCanceledException)
			{
			}
		});
	}

	private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		await CheckWalletStillMatchesAsync();
	}

	private async Task CheckWalletStillMatchesAsync()
	{
		if (_checkingWallet)
			return;

		try
		{
			_checkingWallet = true;

			var currentWallet = await WalletService.GetCurrentAddressAsync();

			if (!AppState.AuthResolved)
			{
				AppState.AuthResolved = true;
				await InvokeAsync(StateHasChanged);
			}

			var currentPath = new Uri(Nav.Uri).AbsolutePath.ToLowerInvariant();

			if (currentPath == "/login")
				return;

			if (string.IsNullOrWhiteSpace(AppState.WalletAddress))
				return;

			if (string.IsNullOrWhiteSpace(currentWallet) ||
				!string.Equals(AppState.WalletAddress, currentWallet, StringComparison.OrdinalIgnoreCase))
			{
				AppState.ResetSession();
				AppState.AuthResolved = true;
				
				if (!string.IsNullOrEmpty(AppState.ReturnUrl))
				{
					var returnUrl = AppState.ReturnUrl;

					AppState.ReturnUrl = null;

					Nav.NavigateTo(returnUrl, false);
				}
				else
				{
					Nav.NavigateTo("/", false);
				}
			}
		}
		finally
		{
			_checkingWallet = false;
		}
	}

	public void Dispose()
	{
		AppState.OnChange -= StateHasChanged;
		Network.OnChanged -= HandleNetworkChanged;
		Nav.LocationChanged -= HandleLocationChanged;

		_bulletinCts?.Cancel();
		_bulletinTimer?.Dispose();
		_bulletinCts?.Dispose();
	}

	private async void HandleNetworkChanged()
	{
		await SuiInterop.InitAsync(
			Network.Current.Network.ToString().ToLowerInvariant(),
			Network.Current.RpcUrl,
			Network.Current.PreferredWallet
		);

		await InvokeAsync(StateHasChanged);
	}

	private void ForceFullReload(MenuItemEventArgs args)
	{
		Nav.NavigateTo(Nav.Uri, forceLoad: true);
	}
}
